# Copy to .env and fill in. Never commit the real values.

# --- Required to run ---
DATABASE_URL=postgresql://user:password@host/db?sslmode=require
PORT=3001                       # api-server port (frontend uses its own)
APP_BASE_URL=http://localhost:3000

# --- Auth ---
MAGIC_LINK_SECRET=              # openssl rand -hex 32
SESSION_SECRET=                 # openssl rand -hex 32
# Replit OIDC (admin login; being phased out)
# REPL_ID=
# ISSUER_URL=https://replit.com/oidc

# --- Email (optional in dev; magic links are logged when unset) ---
# RESEND_API_KEY=
# EMAIL_FROM="Hikaya <hello@yourdomain.com>"

# --- Payments (test mode first) ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PLUS_MONTHLY=price_...
# STRIPE_PRICE_PLUS_ANNUAL=price_...

# --- Audio generation (admin) ---
# ELEVENLABS_API_KEY=

# --- Analytics (frontend, Vite env) ---
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://eu.posthog.com
